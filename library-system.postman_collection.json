          "raw": "{\n  \"name\": \"Laila\",\n  \"email\": \"laila@test.com\",\n  \"phone\": \"123456\",\n  \"password\": \"123456\",\n  \"role\": \"member\",\n  \"address\": \"Sofia\",\n  \"dateOfBirth\": \"2000-01-01\"\n}"
